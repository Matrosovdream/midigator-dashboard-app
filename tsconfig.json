{
    "extends": "@vue/tsconfig/tsconfig.dom.json",
    "compilerOptions": {
        "paths": {
            "@/*": ["./resources/js/*"]
        },
        "types": ["vite/client", "node"]
    },
    "include": [
        "resources/js/**/*.ts",
        "resources/js/**/*.tsx",
        "resources/js/**/*.vue",
        "vite.config.ts"
    ]
}
